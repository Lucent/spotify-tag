# Spotify API credentials (from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Application URL (used for OAuth callback - must match Spotify app settings)
APP_URL=https://tagify.me

# Cloudflare Tunnel token (from Cloudflare Zero Trust dashboard)
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
